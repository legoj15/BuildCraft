{
    "textures": {
        "#trunk_blue":"buildcraftunofficial:block/engine/trunk_blue",
        "#trunk_green":"buildcraftunofficial:block/engine/trunk_green",
        "#trunk_yellow":"buildcraftunofficial:block/engine/trunk_yellow",
        "#trunk_red":"buildcraftunofficial:block/engine/trunk_red",
        "#trunk_overheat":"buildcraftunofficial:block/engine/trunk_black",
        "#trunk_black":"buildcraftunofficial:block/engine/trunk_black",
        "#chamber":"buildcraftunofficial:block/engine/chamber_base",

        "#back":"buildcraftunofficial:block/mj_dynamo/back",
        "#front":"buildcraftunofficial:block/mj_dynamo/front",
        "#side":"buildcraftunofficial:block/mj_dynamo/side"
    },
    "shade":true,
    "variables": {
        "progress_size": "(progress > 0.5 ? ((1 - progress) * (8 * 2 - 0.01)) : (progress * (8 * 2 - 0.01)))",
        "trunk_tex": "'#trunk_' + stage",
        "stage_light":"(stage == overheat || stage == red) ? 10 : stage == yellow ? 7 : stage == green ?  4 : 0"
    },
    "rules": [
        {
            "when": "direction != Facing.UP",
            "type": "builtin:rotate_facing",
            "from": "Facing.UP",
            "to": "direction"
        }
    ],
    "elements": [
        {
            "name":"base",
            "from": [ 0, 0, 0 ],
            "to": [ 16, 4, 16 ],
            "faces": {
                "down":  { "uv": [ 0, 0, 16, 16 ], "texture": "'#back'" },
                "up":    { "uv": [ 0, 0, 16, 16 ], "texture": "'#back'" },
                "north": { "uv": [ 0, 0, 16, 4 ], "texture": "'#side'" },
                "south": { "uv": [ 0, 0, 16, 4 ], "texture": "'#side'" },
                "west":  { "uv": [ 0, 0, 16, 4 ], "texture": "'#side'"},
                "east":  { "uv": [ 0, 0, 16, 4 ], "texture": "'#side'" }
            }
        },
        {
            "name":"base_moving",
            "from": [ 2, "4 + progress_size", 2 ],
            "to": [ 14,  "8 + progress_size", 14 ],
            "faces": {
                "down":  { "uv": [ 0, 0, 12, 12 ], "texture": "'#front'" },
                "up":    { "uv": [ 0, 0, 12, 12 ], "texture": "'#front'" },
                "north": { "uv": [ 0, 12, 12, 16 ], "texture": "'#front'" },
                "south": { "uv": [ 0, 12, 12, 16 ], "texture": "'#front'" },
                "west":  { "uv": [ 0, 12, 12, 16 ], "texture": "'#front'"},
                "east":  { "uv": [ 0, 12, 12, 16 ], "texture": "'#front'" }
            }
        },
        {
            "name":"trunk",
            "from": [ 4, 4, 4 ],
            "to": [ 12, 16, 12],
            "light":"stage_light",
            "faces": {
                "down":  { "uv": [ 0, 0, 8, 8 ], "texture": "trunk_tex" },
                "up":    { "uv": [ 0, 0, 8, 8 ], "texture": "trunk_tex" },
                "north": { "uv": [ 8, 0, 16, 12 ], "texture": "trunk_tex" },
                "south": { "uv": [ 8, 0, 16, 12 ], "texture": "trunk_tex" },
                "west":  { "uv": [ 8, 0, 16, 12 ], "texture": "trunk_tex"},
                "east":  { "uv": [ 8, 0, 16, 12 ], "texture": "trunk_tex" }
            }
        },
        {
            "name":"chamber",
            "from": [ 3, 4, 3 ],
            "to": [ 13, "4 + progress_size", 13 ],
            "faces": {
                "north": { "uv": [ 3, "progress_size", 13, 0 ], "texture": "'#chamber'" },
                "south": { "uv": [ 3, "progress_size", 13, 0 ], "texture": "'#chamber'" },
                "west":  { "uv": [ 3, "progress_size", 13, 0 ], "texture": "'#chamber'" },
                "east":  { "uv": [ 3, "progress_size", 13, 0 ], "texture": "'#chamber'" }
            }
        }
    ]
}
