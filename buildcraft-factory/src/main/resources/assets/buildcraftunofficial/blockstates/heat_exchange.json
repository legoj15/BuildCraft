{
    "multipart": [
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "y": 90 },   "when": { "facing": "north", "part": "start" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "y": 180 },  "when": { "facing": "east",  "part": "start" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "y": 270 },  "when": { "facing": "south", "part": "start" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner" },             "when": { "facing": "west",  "part": "start" }},

        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "x": 180, "y": 90 },   "when": { "facing": "north", "part": "end" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "x": 180, "y": 180 },  "when": { "facing": "east",  "part": "end" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "x": 180, "y": 270 },  "when": { "facing": "south", "part": "end" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_joiner", "x": 180 },             "when": { "facing": "west",  "part": "end" }},

        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_middle" },            "when": { "facing": "north", "part": "middle" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_middle", "y": 90 },   "when": { "facing": "east",  "part": "middle" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_middle", "y": 180 },  "when": { "facing": "south", "part": "middle" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_middle", "y": 270 },  "when": { "facing": "west",  "part": "middle" }},

        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap_left" },            "when": { "facing": "north", "part": "middle", "connected_left": "false" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap_left", "y": 90 },   "when": { "facing": "east",  "part": "middle", "connected_left": "false" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap_left", "y": 180 },  "when": { "facing": "south", "part": "middle", "connected_left": "false" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap_left", "y": 270 },  "when": { "facing": "west",  "part": "middle", "connected_left": "false" }},

        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap" },            "when": { "facing": "north", "part": "middle", "connected_right": "false" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap", "y": 90 },   "when": { "facing": "east",  "part": "middle", "connected_right": "false" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap", "y": 180 },  "when": { "facing": "south", "part": "middle", "connected_right": "false" }},
        {"apply": { "model": "buildcraftunofficial:block/heat_exchange_cap", "y": 270 },  "when": { "facing": "west",  "part": "middle", "connected_right": "false" }}
    ]
}