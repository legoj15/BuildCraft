package buildcraft.test.lib.fluid;

import org.junit.jupiter.api.Assertions;

import net.minecraft.world.level.material.Fluids;
import net.neoforged.neoforge.fluids.FluidStack;

import net.neoforged.testframework.gametest.GameTest;
import net.neoforged.testframework.gametest.ExtendedGameTestHelper;
import net.neoforged.testframework.gametest.EmptyTemplate;
import net.neoforged.testframework.annotation.TestHolder;

import buildcraft.lib.fluid.Tank;
import buildcraft.lib.fluid.TankManager;

public class TankManagerTester {
    @GameTest
    @EmptyTemplate
    @TestHolder(description = "Testing tank manager moving")
    public static void testSimpleMoving(ExtendedGameTestHelper helper) {
        TankManager manager = new TankManager();
        manager.add(new Tank("tank_1", 3, null));
        Assertions.assertEquals(2, manager.fill(new FluidStack(Fluids.WATER, 2), true));
        Assertions.assertEquals(1, manager.fill(new FluidStack(Fluids.WATER, 2), true));
        Assertions.assertTrue(FluidStack.isSameFluidSameComponents(new FluidStack(Fluids.WATER, 3), manager.drain(new FluidStack(Fluids.WATER, 5), true)));

        manager.add(new Tank("tank_2", 3, null));

        Assertions.assertEquals(5, manager.fill(new FluidStack(Fluids.LAVA, 5), true));
        Assertions.assertTrue(FluidStack.isSameFluidSameComponents(new FluidStack(Fluids.LAVA, 4), manager.drain(new FluidStack(Fluids.LAVA, 4), true)));

        Assertions.assertEquals(1, manager.get(1).getFluid().getAmount());
    }
}
